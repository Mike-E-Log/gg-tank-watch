{\n  "events": [\n    {\n      "id": "evt-20260521-001",\n      "timestamp_utc": "2026-05-21T22:30:00Z",\n      "timestamp_local": "2026-05-21T15:30:00-07:00",\n      "day": 1,\n      "title": "OCFA responds to toxic chemical leak at GKN Aerospace",\n      "description": "OCFA crews and Garden Grove PD respond to reports of toxic chemical leak at GKN Aerospace Transparency Systems, 12122 Western Ave, Garden Grove.",\n      "source_url": "https://abc7.com/post/tank-spews-toxic-chemicals-garden-grove-prompting-evacuation-orders/19150431/",\n      "source_name": "ABC7 LA",\n      "category": "initial_response"\n    },\n    {\n      "id": "evt-20260521-002",\n      "timestamp_utc": "2026-05-21T22:40:00Z",\n      "timestamp_local": "2026-05-21T15:40:00-07:00",\n      "day": 1,\n      "title": "34,000-gallon MMA tank confirmed overheated and off-gassing vapor",\n      "description": "OCFA confirms 34,000-gallon tank containing ~7,000 gallons of methyl methacrylate (MMA) has overheated and is off-gassing vapor. Relief valve and sprinkler system activated automatically.",\n      "source_url": "https://en.wikipedia.org/wiki/Garden_Grove_chemical_leak",\n      "source_name": "Wikipedia",\n      "category": "tank_status"\n    },\n    {\n      "id": "evt-20260521-003",\n      "timestamp_utc": "2026-05-21T23:00:00Z",\n      "timestamp_local": "2026-05-21T16:00:00-07:00",\n      "day": 1,\n      "title": "OCFA Captain Doran briefs media on overheated industrial tank",\n      "description": "OCFA Captain Sean Doran briefs media: \\"We arrived to a 34,000-gallon tank containing an industrial chemical that had been overheated inside the vessel.\\" Tank\'s sprinkler system activated as designed.",\n      "source_url": "https://ktla.com/news/orange-county/timeline-orange-county-chemical-tank-crisis/",\n      "source_name": "KTLA",\n      "category": "official_statement"\n    },\n    {\n      "id": "evt-20260521-004",\n      "timestamp_utc": "2026-05-21T23:00:00Z",\n      "timestamp_local": "2026-05-21T16:00:00-07:00",\n      "day": 1,\n      "title": "Initial evacuation orders issued for areas around GKN facility",\n      "description": "Initial evacuation orders issued for areas north of Garden Grove Blvd, east of Monarch St, south of Orangewood Ave, west of Beach Blvd.",\n      "source_url": "https://ktla.com/news/orange-county/thousands-evacuated-toxic-chemicals-spew-into-air-garden-grove/",\n      "source_name": "KTLA",\n      "category": "evacuation"\n    },\n    {\n      "id": "evt-20260522-001",\n      "timestamp_utc": "2026-05-22T03:40:00Z",\n      "timestamp_local": "2026-05-21T20:40:00-07:00",\n      "day": 1,\n      "title": "Day 1 evacuation orders lifted after cooling operations",\n      "description": "Evacuation orders lifted after crews spend hours cooling tank with water hoses and reducing vapor production.",\n      "source_url": "https://ktla.com/news/orange-county/timeline-orange-county-chemical-tank-crisis/",\n      "source_name": "KTLA",\n      "category": "evacuation"\n    },\n    {\n      "id": "evt-20260522-002",\n      "timestamp_utc": "2026-05-22T13:30:00Z",\n      "timestamp_local": "2026-05-22T06:30:00-07:00",\n      "day": 2,\n      "title": "OCFA reissues evacuation orders due to changing conditions",\n      "description": "OCFA reissues evacuation orders \\"due to changing conditions.\\" First mention of tank possibly rupturing or exploding.",\n      "source_url": "https://ktla.com/news/orange-county/thousands-evacuated-again-after-toxic-tank-leak-in-garden-grove/",\n      "source_name": "KTLA",\n      "category": "evacuation"\n    },\n    {\n      "id": "evt-20260522-003",\n      "timestamp_utc": "2026-05-22T14:00:00Z",\n      "timestamp_local": "2026-05-22T07:00:00-07:00",\n      "day": 2,\n      "title": "Initial Day 2 evacuation zone defined",\n      "description": "Initial evacuation zone: north of Garden Grove Blvd, east of Springdale Ave, west of Dale St, south of Orangewood Ave.",\n      "source_url": "https://abc7.com/post/tank-spews-toxic-chemicals-garden-grove-prompting-evacuation-orders/19150431/",\n      "source_name": "ABC7 LA",\n      "category": "evacuation"\n    },\n    {\n      "id": "evt-20260522-004",\n      "timestamp_utc": "2026-05-22T17:00:00Z",\n      "timestamp_local": "2026-05-22T10:00:00-07:00",\n      "day": 2,\n      "title": "Tank temperature reads 77°F; cooling operations begin",\n      "description": "Tank temperature read at 77°F in the morning; responders begin water-cooling operations.",\n      "source_url": "https://www.nbclosangeles.com/news/local/garden-grove-gas-leak-temperature/3894210/",\n      "source_name": "NBC LA",\n      "category": "tank_status"\n    },\n    {\n      "id": "evt-20260522-005",\n      "timestamp_utc": "2026-05-22T17:40:00Z",\n      "timestamp_local": "2026-05-22T10:40:00-07:00",\n      "day": 2,\n      "title": "Evacuation zone expanded to 1-mile buffer, ~40,000 people affected",\n      "description": "Evacuation zone expanded to north of Trask Ave, south of Ball Rd, east of Valley View St, west of Dale St — creating ~1-mile buffer around tank. ~40,000 people affected.",\n      "source_url": "https://patch.com/california/orange-county/garden-grove-hazmat-crisis-map-updated-evacuation-zone",\n      "source_name": "OC Patch",\n      "category": "evacuation"\n    },\n    {\n      "id": "evt-20260522-006",\n      "timestamp_utc": "2026-05-22T19:00:00Z",\n      "timestamp_local": "2026-05-22T12:00:00-07:00",\n      "day": 2,\n      "title": "OCFA Chief Covey warns of only two outcomes: spill or explosion",\n      "description": "OCFA Division Chief Craig Covey afternoon briefing: tank is \\"actively in crisis.\\" Warns of only two outcomes — chemical spill or thermal runaway explosion. \\"There are literally two options left remaining.\\"",\n      "source_url": "https://ktla.com/news/orange-county/thousands-evacuated-again-after-toxic-tank-leak-in-garden-grove/",\n      "source_name": "KTLA",\n      "category": "official_statement"\n    },\n    {\n      "id": "evt-20260522-007",\n      "timestamp_utc": "2026-05-22T19:00:00Z",\n      "timestamp_local": "2026-05-22T12:00:00-07:00",\n      "day": 2,\n      "title": "Faulty valve identified as core problem preventing tank neutralization",\n      "description": "Faulty valve identified as core problem — valve seized due to chemical reaction, preventing neutralization or draining of tank contents.",\n      "source_url": "https://abcnews.com/US/evacuation-orders-issued-california-city-chemical-tank-fails/story?id=133234846",\n      "source_name": "ABC News",\n      "category": "tank_status"\n    },\n    {\n      "id": "evt-20260522-008",\n      "timestamp_utc": "2026-05-22T20:00:00Z",\n      "timestamp_local": "2026-05-22T13:00:00-07:00",\n      "day": 2,\n      "title": "~15% of evacuees (~6,000 people) refusing to leave",\n      "description": "Garden Grove Police Chief Amir El-Farra reports ~15% of evacuees (~6,000 people) refusing to leave.",\n      "source_url": "https://edition.cnn.com/2026/05/22/us/chemical-spill-orange-county-california",\n      "source_name": "CNN",\n      "category": "community_impact"\n    },\n    {\n      "id": "evt-20260522-009",\n      "timestamp_utc": "2026-05-22T22:00:00Z",\n      "timestamp_local": "2026-05-22T15:00:00-07:00",\n      "day": 2,\n      "title": "Over a dozen schools close; GGUSD announces closures",\n      "description": "Over a dozen schools temporarily close; schools adjacent to evacuation area cancel outdoor activities. GGUSD announces closures.",\n      "source_url": "https://abc7.com/post/tank-spews-toxic-chemicals-garden-grove-prompting-evacuation-orders/19150431/",\n      "source_name": "ABC7 LA",\n      "category": "school_closure"\n    },\n    {\n      "id": "evt-20260522-010",\n      "timestamp_utc": "2026-05-22T22:00:00Z",\n      "timestamp_local": "2026-05-22T15:00:00-07:00",\n      "day": 2,\n      "title": "OC District Attorney opens investigation; anonymous tip line launched",\n      "description": "Orange County District Attorney Todd Spitzer begins investigation; investigators survey site via drones. Orders GKN Aerospace to preserve records. Anonymous tip line opened (714-347-8714).",\n      "source_url": "https://www.cbsnews.com/losangeles/news/garden-grove-gkn-aerospace-chemical-leak-investigation-orange-county-district-attorney-whistleblowers/",\n      "source_name": "CBS LA",\n      "category": "government_action"\n    },\n    {\n      "id": "evt-20260522-011",\n      "timestamp_utc": "2026-05-22T23:00:00Z",\n      "timestamp_local": "2026-05-22T16:00:00-07:00",\n      "day": 2,\n      "title": "Night team reads tank at 90°F — higher than drone readings indicated",\n      "description": "Night team approaches neighboring tank for neutralization attempt; reads internal temperature gauge at 90°F — significantly higher than 77°F morning reading. External drone readings had been misleading.",\n      "source_url": "https://www.nbclosangeles.com/news/local/garden-grove-gas-leak-temperature/3894210/",\n      "source_name": "NBC LA",\n      "category": "tank_status"\n    },\n    {\n      "id": "evt-20260522-012",\n      "timestamp_utc": "2026-05-22T23:59:00Z",\n      "timestamp_local": "2026-05-22T16:59:00-07:00",\n      "day": 2,\n      "title": "NPR and CNN pick up story nationally",\n      "description": "NPR picks up story nationally. CNN begins live coverage.",\n      "source_url": "https://www.npr.org/2026/05/22/g-s1-124082/garden-grove-chemical-tank-leak",\n      "source_name": "NPR",\n      "category": "media_coverage"\n    },\n    {\n      "id": "evt-20260523-001",\n      "timestamp_utc": "2026-05-23T14:00:00Z",\n      "timestamp_local": "2026-05-23T07:00:00-07:00",\n      "day": 3,\n      "title": "OCFA morning briefing: tank continued heating despite stabilization signs",\n      "description": "OCFA morning briefing: tank continued to heat internally despite earlier signs of stabilization. Incident Commander Covey says cooling efforts based on external drone readings \\"proved incorrect.\\"",\n      "source_url": "https://ktla.com/news/orange-county/timeline-orange-county-chemical-tank-crisis/",\n      "source_name": "KTLA",\n      "category": "official_statement"\n    },\n    {\n      "id": "evt-20260523-002",\n      "timestamp_utc": "2026-05-23T15:00:00Z",\n      "timestamp_local": "2026-05-23T08:00:00-07:00",\n      "day": 3,\n      "title": "Tank temperature rising at ~1°F per hour",\n      "description": "Temperature rising at ~1°F per hour per OCFA Incident Commander Covey.",\n      "source_url": "https://abcnews.com/US/evacuation-orders-issued-california-city-chemical-tank-fails/story?id=133234846",\n      "source_name": "ABC News",\n      "category": "tank_status"\n    },\n    {\n      "id": "evt-20260523-003",\n      "timestamp_utc": "2026-05-23T17:00:00Z",\n      "timestamp_local": "2026-05-23T10:00:00-07:00",\n      "day": 3,\n      "title": "Evacuation expanded to ~50,000 people across 9 square miles",\n      "description": "Evacuation expanded to ~50,000 people across 9 square miles — including parts of Anaheim, Buena Park, Cypress, Stanton, and Westminster.",\n      "source_url": "https://en.wikipedia.org/wiki/Garden_Grove_chemical_leak",\n      "source_name": "Wikipedia",\n      "category": "evacuation"\n    },\n    {\n      "id": "evt-20260523-004",\n      "timestamp_utc": "2026-05-23T17:00:00Z",\n      "timestamp_local": "2026-05-23T10:00:00-07:00",\n      "day": 3,\n      "title": "Blast zone and impact zone maps released; health effects described",\n      "description": "OCFA Division Chief Nick Freeman and OC Health Officer Dr. Regina Chinsio-Kwong release blast zone and impact zone maps. Dr. Chinsio-Kwong warns MMA can cause respiratory issues, itching/burning eyes, nausea, headaches.",\n      "source_url": "https://ktla.com/news/orange-county/map-potential-blast-zones-chemical-tank-explode-garden-grove/",\n      "source_name": "KTLA",\n      "category": "official_statement"\n    },\n    {\n      "id": "evt-20260523-005",\n      "timestamp_utc": "2026-05-23T17:30:00Z",\n      "timestamp_local": "2026-05-23T10:30:00-07:00",\n      "day": 3,\n      "title": "Covey warns Friday\'s positive indications may have been false flags",\n      "description": "OCFA Division Chief Covey releases 5-minute critical incident briefing: positive indications from Friday\'s investigation \\"may have been false flags.\\"",\n      "source_url": "https://ktla.com/news/orange-county/timeline-orange-county-chemical-tank-crisis/",\n      "source_name": "KTLA",\n      "category": "official_statement"\n    },\n    {\n      "id": "evt-20260523-006",\n      "timestamp_utc": "2026-05-23T18:00:00Z",\n      "timestamp_local": "2026-05-23T11:00:00-07:00",\n      "day": 3,\n      "title": "First responders pulled back; remote water spraying continues",\n      "description": "First responders pulled back from immediate area around tank for safety; continue remotely spraying water.",\n      "source_url": "https://abcnews.com/US/evacuation-orders-issued-california-city-chemical-tank-fails/story?id=133234846",\n      "source_name": "ABC News",\n      "category": "initial_response"\n    },\n    {\n      "id": "evt-20260523-007",\n      "timestamp_utc": "2026-05-23T18:00:00Z",\n      "timestamp_local": "2026-05-23T11:00:00-07:00",\n      "day": 3,\n      "title": "Containment channels built to protect storm drains if tank ruptures",\n      "description": "Responders construct channels and containment areas to prevent liquid MMA from flowing into storm drains, waterways, or ocean if tank ruptures.",\n      "source_url": "https://en.wikipedia.org/wiki/Garden_Grove_chemical_leak",\n      "source_name": "Wikipedia",\n      "category": "initial_response"\n    },\n    {\n      "id": "evt-20260523-008",\n      "timestamp_utc": "2026-05-23T19:00:00Z",\n      "timestamp_local": "2026-05-23T12:00:00-07:00",\n      "day": 3,\n      "title": "Governor Newsom declares state of emergency in Orange County",\n      "description": "Governor Gavin Newsom declares state of emergency in Orange County. Directs Cal OES and all state agencies to support response. Makes state-owned properties and fairgrounds available for sheltering.",\n      "source_url": "https://www.gov.ca.gov/2026/05/23/governor-newsom-proclaims-state-of-emergency-in-orange-county-in-response-to-ongoing-chemical-incident-in-garden-grove-makes-additional-shelter-sites-available/",\n      "source_name": "Gov.ca.gov",\n      "category": "government_action"\n    },\n    {\n      "id": "evt-20260523-009",\n      "timestamp_utc": "2026-05-23T20:00:00Z",\n      "timestamp_local": "2026-05-23T13:00:00-07:00",\n      "day": 3,\n      "title": "Potential crack discovered in tank; may be relieving pressure",\n      "description": "OCFA Interim Fire Chief TJ McGovern reports potential crack discovered in tank. No liquid leaking through crack. Crack may be relieving internal pressure, potentially preventing explosion.",\n      "source_url": "https://en.wikipedia.org/wiki/Garden_Grove_chemical_leak",\n      "source_name": "Wikipedia",\n      "category": "tank_status"\n    },\n    {\n      "id": "evt-20260523-010",\n      "timestamp_utc": "2026-05-23T20:30:00Z",\n      "timestamp_local": "2026-05-23T13:30:00-07:00",\n      "day": 3,\n      "title": "Newsom requests federal emergency declaration from President Trump",\n      "description": "Newsom requests President Trump issue federal emergency declaration. Senators Padilla and Schiff, Rep. Derek Tran send letters urging approval.",\n      "source_url": "https://ktla.com/news/state-of-emergency-garden-grove-chemical-incident/",\n      "source_name": "KTLA",\n      "category": "government_action"\n    },\n    {\n      "id": "evt-20260523-011",\n      "timestamp_utc": "2026-05-23T21:00:00Z",\n      "timestamp_local": "2026-05-23T14:00:00-07:00",\n      "day": 3,\n      "title": "Class-action lawsuit filed against GKN Aerospace",\n      "description": "Class-action lawsuit filed against GKN Aerospace by X-Law Group P.C. and Presidio Law Firm on behalf of two Garden Grove residents. Seeks damages in hundreds of millions or billions.",\n      "source_url": "https://en.wikipedia.org/wiki/Garden_Grove_chemical_leak",\n      "source_name": "Wikipedia",\n      "category": "government_action"\n    },\n    {\n      "id": "evt-20260523-012",\n      "timestamp_utc": "2026-05-23T21:30:00Z",\n      "timestamp_local": "2026-05-23T14:30:00-07:00",\n      "day": 3,\n      "title": "Covey: \\"This is as real as it gets. Worst-case scenario I\'ve ever faced.\\"",\n      "description": "OCFA Division Chief Craig Covey: \\"This is as real as it gets. It\'s the worst-case scenario I\'ve ever faced in my career.\\"",\n      "source_url": "https://abcnews.com/US/evacuation-orders-issued-california-city-chemical-tank-fails/story?id=133234846",\n      "source_name": "ABC News",\n      "category": "official_statement"\n    },\n    {\n      "id": "evt-20260523-013",\n      "timestamp_utc": "2026-05-23T22:00:00Z",\n      "timestamp_local": "2026-05-23T15:00:00-07:00",\n      "day": 3,\n      "title": "Evacuation shelters opened across Orange County",\n      "description": "Evacuation shelters opened: JFK High School (La Palma), Savanna High School (Anaheim), Oceanview High School (Huntington Beach), Mile Square Regional Park Freedom Hall (Fountain Valley), Los Amigos High School (Fountain Valley), Golden West College (Huntington Beach). OC Fair & Event Center (Costa Mesa) opens for RV parking.",\n      "source_url": "https://www.nbclosangeles.com/news/local/garden-grove-chemical-tank-emergency-resources/3894464/",\n      "source_name": "NBC LA",\n      "category": "community_impact"\n    },\n    {\n      "id": "evt-20260523-014",\n      "timestamp_utc": "2026-05-23T22:30:00Z",\n      "timestamp_local": "2026-05-23T15:30:00-07:00",\n      "day": 3,\n      "title": "CA Attorney General urges evacuees to report price gouging",\n      "description": "California Attorney General Rob Bonta urges evacuees to report price gouging.",\n      "source_url": "https://www.npr.org/2026/05/24/nx-s1-5833165/california-chemical-tank-malfunction-leak-explode-emergency-evacuate",\n      "source_name": "NPR",\n      "category": "government_action"\n    },\n    {\n      "id": "evt-20260523-015",\n      "timestamp_utc": "2026-05-23T23:00:00Z",\n      "timestamp_local": "2026-05-23T16:00:00-07:00",\n      "day": 3,\n      "title": "International media coverage begins; Vietnamese-language stations translate updates",\n      "description": "News18 (India) begins live international coverage. ABC News national runs \\"What to know 48 hours in\\" segment. Local Vietnamese radio and TV stations begin translating emergency updates for non-English-speaking residents. Garden Grove city website posts alerts in Vietnamese, Korean, and Spanish.",\n      "source_url": "https://e.vnexpress.net/news/life/trend/vietnamese-residents-in-us-s-orange-county-anxious-over-risk-of-chemical-tank-explosion-5078004.html",\n      "source_name": "VnExpress",\n      "category": "community_impact"\n    },\n    {\n      "id": "evt-20260524-001",\n      "timestamp_utc": "2026-05-24T07:00:00Z",\n      "timestamp_local": "2026-05-24T00:00:00-07:00",\n      "day": 4,\n      "title": "OCFA announces all-night operation to assess tank pressure relief",\n      "description": "OCFA announces all-night operation to determine whether excess tank pressure has been relieved.",\n      "source_url": "https://en.wikipedia.org/wiki/Garden_Grove_chemical_leak",\n      "source_name": "Wikipedia",\n      "category": "tank_status"\n    },\n    {\n      "id": "evt-20260524-002",\n      "timestamp_utc": "2026-05-24T14:00:00Z",\n      "timestamp_local": "2026-05-24T07:00:00-07:00",\n      "day": 4,\n      "title": "Tank temperature reaches 100°F — maxing out gauge reading limit",\n      "description": "Tank temperature reaches at least 100°F — maxing out gauge\'s reading limit.",\n      "source_url": "https://www.nbclosangeles.com/news/local/garden-grove-gas-leak-temperature/3894210/",\n      "source_name": "NBC LA",\n      "category": "tank_status"\n    },\n    {\n      "id": "evt-20260524-003",\n      "timestamp_utc": "2026-05-24T16:00:00Z",\n      "timestamp_local": "2026-05-24T09:00:00-07:00",\n      "day": 4,\n      "title": "GKN team begins removing external tank insulation to aid cooling",\n      "description": "GKN Aerospace team works with OCFA to remove external insulation from tank to help cool chemicals inside.",\n      "source_url": "https://en.wikipedia.org/wiki/Garden_Grove_chemical_leak",\n      "source_name": "Wikipedia",\n      "category": "tank_status"\n    },\n    {\n      "id": "evt-20260524-004",\n      "timestamp_utc": "2026-05-24T19:00:00Z",\n      "timestamp_local": "2026-05-24T12:00:00-07:00",\n      "day": 4,\n      "title": "785 state and local first responders deployed to Orange County",\n      "description": "Governor Newsom\'s office reports 785 state and local first responders deployed to Orange County.",\n      "source_url": "https://www.gov.ca.gov/2026/05/24/governor-newsom-submits-request-to-president-trump-for-emergency-declaration-to-support-response-efforts-in-orange-county/",\n      "source_name": "Gov.ca.gov",\n      "category": "government_action"\n    },\n    {\n      "id": "evt-20260524-005",\n      "timestamp_utc": "2026-05-24T19:00:00Z",\n      "timestamp_local": "2026-05-24T12:00:00-07:00",\n      "day": 4,\n      "title": "24 air quality monitors deployed; readings completely normal",\n      "description": "South Coast AQMD and US EPA confirm 24 air quality monitors deployed around evacuation zone; air quality levels remain \\"completely normal.\\" EPA dispatches two on-scene coordinators.",\n      "source_url": "https://en.wikipedia.org/wiki/Garden_Grove_chemical_leak",\n      "source_name": "Wikipedia",\n      "category": "air_quality"\n    },\n    {\n      "id": "evt-20260524-006",\n      "timestamp_utc": "2026-05-24T19:00:00Z",\n      "timestamp_local": "2026-05-24T12:00:00-07:00",\n      "day": 4,\n      "title": "EPA Administrator Zeldin: \\"Tank will fail\\" but likely low-volume release",\n      "description": "EPA Administrator Lee Zeldin tells CNN: \\"The most likely scenario is one of a low-volume release, where the local authorities are going to be able to monitor, neutralize, and contain the threat.\\" Confirms \\"the tank will fail.\\"",\n      "source_url": "https://www.washingtonexaminer.com/policy/energy-and-environment/4581025/zeldin-release-may-contain-garden-grove-chemical-crisis-what-to-know/",\n      "source_name": "Washington Examiner",\n      "category": "official_statement"\n    },\n    {\n      "id": "evt-20260524-007",\n      "timestamp_utc": "2026-05-24T20:00:00Z",\n      "timestamp_local": "2026-05-24T13:00:00-07:00",\n      "day": 4,\n      "title": "FEMA deploys liaison; activates atmospheric assessment center",\n      "description": "FEMA deploys Liaison Officer and team to State Emergency Operations Center. Activates Interagency Modeling and Atmospheric Assessment Center for plume modeling. White House confirms EPA has air monitoring at 20 locations.",\n      "source_url": "https://www.cbsnews.com/news/garden-grove-methyl-methacrylate-chemical-tank-california/",\n      "source_name": "CBS News",\n      "category": "government_action"\n    },\n    {\n      "id": "evt-20260524-008",\n      "timestamp_utc": "2026-05-24T22:30:00Z",\n      "timestamp_local": "2026-05-24T15:30:00-07:00",\n      "day": 4,\n      "title": "Temporary shelters reach full capacity for overnight stays",\n      "description": "Orange County officials report temporary shelters at full capacity for overnight stays.",\n      "source_url": "https://e.vnexpress.net/news/life/trend/vietnamese-residents-in-us-s-orange-county-anxious-over-risk-of-chemical-tank-explosion-5078004.html",\n      "source_name": "VnExpress",\n      "category": "community_impact"\n    },\n    {\n      "id": "evt-20260524-009",\n      "timestamp_utc": "2026-05-24T23:00:00Z",\n      "timestamp_local": "2026-05-24T16:00:00-07:00",\n      "day": 4,\n      "title": "Joint operation successfully removes insulation; crack confirmed relieving pressure",\n      "description": "Technical specialists conduct joint operation with OCFA to assess tank more closely; successfully remove external insulation material. During operation, identify crack relieving pressure.",\n      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/entry/19163069/",\n      "source_name": "ABC7 LA",\n      "category": "tank_status"\n    },\n    {\n      "id": "evt-20260524-010",\n      "timestamp_utc": "2026-05-24T23:30:00Z",\n      "timestamp_local": "2026-05-24T16:30:00-07:00",\n      "day": 4,\n      "title": "12 GGUSD campuses confirmed closed through May 27",\n      "description": "12 GGUSD campuses confirmed closed through May 27 (final school day): Barker, Bryant, Carver, Enders, Garden Park, Lawrence, Wakeham, Patton (elementary); Bell, Alamitos (intermediate); Pacifica, Rancho Alamitos (high school). Distance learning for final 2 instructional days, no penalties.",\n      "source_url": "https://newsroom.ocde.us/several-garden-grove-unified-campuses-closed-following-chemical-leak-response/",\n      "source_name": "OCDE Newsroom",\n      "category": "school_closure"\n    },\n    {\n      "id": "evt-20260524-011",\n      "timestamp_utc": "2026-05-24T23:30:00Z",\n      "timestamp_local": "2026-05-24T16:30:00-07:00",\n      "day": 4,\n      "title": "Multiple school districts beyond GGUSD announce closures",\n      "description": "Westminster SD closes Fryberger, Sequoia and other schools; Magnolia SD closes Pyles STEM Academy; Savanna SD closes all campuses for week of May 25. Cypress SD gives pickup option for Vessels and Morris Elementary.",\n      "source_url": "https://www.nbclosangeles.com/news/local/gatden-grove-chemical-tank-schools-closed/3894457/",\n      "source_name": "NBC LA",\n      "category": "school_closure"\n    },\n    {\n      "id": "evt-20260524-012",\n      "timestamp_utc": "2026-05-24T23:59:00Z",\n      "timestamp_local": "2026-05-24T16:59:00-07:00",\n      "day": 4,\n      "title": "Uber, gyms, and World Central Kitchen offer support to evacuees",\n      "description": "Uber offers free rides up to $40 to shelters. Planet Fitness, 24 Hour Fitness, LA Fitness open all OC locations to evacuees. World Central Kitchen provides meals alongside local food trucks.",\n      "source_url": "https://www.nbclosangeles.com/news/local/garden-grove-chemical-tank-emergency-resources/3894464/",\n      "source_name": "NBC LA",\n      "category": "community_impact"\n    },\n    {\n      "id": "evt-20260524-013",\n      "timestamp_utc": "2026-05-24T23:59:00Z",\n      "timestamp_local": "2026-05-24T16:59:00-07:00",\n      "day": 4,\n      "title": "Vietnamese community opens private homes; Dieu Ngu Pagoda shelters evacuees",\n      "description": "Vietnamese community members open private homes to evacuees; A Huntington Beach resident shelters 40 people in vacant family properties. Dieu Ngu Pagoda (Westminster) opens for shelter with vegetarian meals.",\n      "source_url": "https://e.vnexpress.net/news/life/trend/vietnamese-residents-in-us-s-orange-county-anxious-over-risk-of-chemical-tank-explosion-5078004.html",\n      "source_name": "VnExpress",\n      "category": "community_impact"\n    },\n    {\n      "id": "evt-20260524-014",\n      "timestamp_utc": "2026-05-24T23:59:00Z",\n      "timestamp_local": "2026-05-24T16:59:00-07:00",\n      "day": 4,\n      "title": "TIME Magazine and Fox News publish national features on crisis",\n      "description": "TIME Magazine publishes feature: \\"Garden Grove: Tens of Thousands Ordered to Evacuate Over Chemical Tank Explosion Risk.\\" Fox News national publishes: \\"Orange County chemical tank \'actively in crisis\' could explode or spill.\\"",\n      "source_url": "https://time.com/article/2026/05/24/garden-grove-chemical-tank-explosion-/",\n      "source_name": "TIME",\n      "category": "media_coverage"\n    },\n    {\n      "id": "evt-20260524-015",\n      "timestamp_utc": "2026-05-24T23:59:00Z",\n      "timestamp_local": "2026-05-24T16:59:00-07:00",\n      "day": 4,\n      "title": "LA Mayor confirms no risk to Los Angeles; neighboring cities monitor",\n      "description": "LA Mayor confirms no risk to city of Los Angeles. Cities of Lakewood, Long Beach, and Hawaiian Gardens monitor situation. LAFD confirms no risk.",\n      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/entry/19159179/",\n      "source_name": "ABC7 LA",\n      "category": "official_statement"\n    },\n    {\n      "id": "evt-20260525-001",\n      "timestamp_utc": "2026-05-25T08:00:00Z",\n      "timestamp_local": "2026-05-25T01:00:00-07:00",\n      "day": 5,\n      "title": "Tank crack verified overnight; pressure releasing through crack",\n      "description": "OCFA Interim Fire Chief TJ McGovern confirms crack in tank verified overnight; pressure releasing through crack.",\n      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/entry/19163069/",\n      "source_name": "ABC7 LA",\n      "category": "tank_status"\n    },\n    {\n      "id": "evt-20260525-002",\n      "timestamp_utc": "2026-05-25T14:00:00Z",\n      "timestamp_local": "2026-05-25T07:00:00-07:00",\n      "day": 5,\n      "title": "BLEVE threat eliminated; tank temperature dropping from 100°F to 93°F",\n      "description": "OCFA morning press conference: BLEVE threat \\"is now off the table.\\" Interim Chief McGovern and Incident Commander Covey confirm crack has relieved tank pressure. Tank temperature dropped from ~100°F to 93°F and continuing to decline.",\n      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/",\n      "source_name": "ABC7 LA",\n      "category": "official_statement"\n    },\n    {\n      "id": "evt-20260525-003",\n      "timestamp_utc": "2026-05-25T14:00:00Z",\n      "timestamp_local": "2026-05-25T07:00:00-07:00",\n      "day": 5,\n      "title": "McGovern cautions: smaller explosion or leak still possible",\n      "description": "McGovern cautions: \\"Crisis is not averted. We still have potential for an explosion that is not as bad as a BLEVE, but it is still a threat.\\" Smaller explosion or leak still possible. No active leak currently.",\n      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/",\n      "source_name": "ABC7 LA",\n      "category": "official_statement"\n    },\n    {\n      "id": "evt-20260525-004",\n      "timestamp_utc": "2026-05-25T14:00:00Z",\n      "timestamp_local": "2026-05-25T07:00:00-07:00",\n      "day": 5,\n      "title": "Only 1 known crack confirmed; liquid MMA status being assessed",\n      "description": "OCFA clarifies only 1 known crack in tank. OCFA PIO Nick Garton: \\"We\'re trying to confirm that there\'s still a liquid form of this chemical that could potentially leak out.\\"",\n      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/entry/19165715/",\n      "source_name": "ABC7 LA",\n      "category": "tank_status"\n    },\n    {\n      "id": "evt-20260525-005",\n      "timestamp_utc": "2026-05-25T14:00:00Z",\n      "timestamp_local": "2026-05-25T07:00:00-07:00",\n      "day": 5,\n      "title": "Firefighters can now enter tank area at reduced risk during daytime",\n      "description": "Elimination of BLEVE threat allows firefighters to enter tank area at reduced risk during daytime hours.",\n      "source_url": "https://www.nbclosangeles.com/news/local/bleve-garden-grove-chemical-tank-explosion/3894920/",\n      "source_name": "NBC LA",\n      "category": "tank_status"\n    },\n    {\n      "id": "evt-20260525-006",\n      "timestamp_utc": "2026-05-25T16:00:00Z",\n      "timestamp_local": "2026-05-25T09:00:00-07:00",\n      "day": 5,\n      "title": "President Trump signs federal emergency declaration for Orange County",\n      "description": "President Trump signs federal emergency declaration for Orange County, per OC Supervisor Janet Nguyen and Rep. Derek Tran. Authorizes FEMA to provide direct federal assistance.",\n      "source_url": "https://www.gov.ca.gov/2026/05/25/governor-newsom-secures-presidential-emergency-declaration-approval-for-orange-county-hazmat-response/",\n      "source_name": "Gov.ca.gov",\n      "category": "government_action"\n    },\n    {\n      "id": "evt-20260525-007",\n      "timestamp_utc": "2026-05-25T18:00:00Z",\n      "timestamp_local": "2026-05-25T11:00:00-07:00",\n      "day": 5,\n      "title": "50,000 residents remain under unchanged evacuation orders",\n      "description": "50,000 residents remain under evacuation orders. Evacuation zone unchanged.",\n      "source_url": "https://www.cbsnews.com/losangeles/live-updates/california-chemical-leak-orange-county-garden-grove-emergency-day-5/",\n      "source_name": "CBS LA",\n      "category": "evacuation"\n    },\n    {\n      "id": "evt-20260525-008",\n      "timestamp_utc": "2026-05-25T18:00:00Z",\n      "timestamp_local": "2026-05-25T11:00:00-07:00",\n      "day": 5,\n      "title": "Air quality remains normal across all 24 monitoring stations",\n      "description": "Air quality levels continue to read normal across all 24 SCAQMD/EPA monitoring stations around evacuation zone.",\n      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/entry/19163312/",\n      "source_name": "ABC7 LA",\n      "category": "air_quality"\n    },\n    {\n      "id": "evt-20260526-001",\n      "timestamp_utc": "2026-05-26T01:00:00Z",\n      "timestamp_local": "2026-05-25T18:00:00-07:00",\n      "day": 5,\n      "title": "Evacuation zone reduced 65%; 34,000 residents can return home",\n      "description": "Evacuation zone reduced from ~50,000 to ~16,000 residents. New boundaries: Orangewood Ave (north), Dale St (east), Knott St (west), Garden Grove Blvd (south). Approximately 65% of impacted residents can return home.",\n      "source_url": "https://www.nbclosangeles.com/news/local/toxic-chemical-tank-garden-grove-orange-county/3894971/",\n      "source_name": "NBC LA",\n      "category": "evacuation"\n    },\n    {\n      "id": "evt-20260526-002",\n      "timestamp_utc": "2026-05-26T04:00:00Z",\n      "timestamp_local": "2026-05-25T21:00:00-07:00",\n      "day": 5,\n      "title": "Overnight operation removes tank insulation to improve cooling",\n      "description": "Firefighters removed weather protection and insulation from the outside of the tank overnight to help water cooling be more efficient at reducing temperature.",\n      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/",\n      "source_name": "ABC7 LA",\n      "category": "tank_status"\n    },\n    {\n      "id": "evt-20260526-003",\n      "timestamp_utc": "2026-05-26T14:00:00Z",\n      "timestamp_local": "2026-05-26T07:00:00-07:00",\n      "day": 6,\n      "title": "OCFA confirms no threat of catastrophic explosion; tank stabilizing",\n      "description": "OCFA confirms there is no longer a threat of a catastrophic explosion. Tank temperature continuing to decrease. Ongoing atmospheric monitoring confirms no chemicals leaking from the crack.",\n      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/",\n      "source_name": "ABC7 LA",\n      "category": "official_statement"\n    },\n    {\n      "id": "evt-20260526-004",\n      "timestamp_utc": "2026-05-26T20:00:00Z",\n      "timestamp_local": "2026-05-26T13:00:00-07:00",\n      "day": 6,\n      "title": "McGovern: worst-case scenario resolved, but incident not over",\n      "description": "OCFA Interim Chief McGovern at Monday afternoon press conference: \\"The most catastrophic and worst-case scenario has been mitigated and resolved, but it\'s not over yet.\\" No injuries to civilians or firefighters throughout the incident. OCFA Incident Commander Covey: \\"The liquid potential in the tank [has been] greatly reduced, as it has been hardened.\\"",\n      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/",\n      "source_name": "ABC7 LA",\n      "category": "official_statement"\n    },\n    {\n      "id": "evt-20260526-006",\n      "timestamp_utc": "2026-05-26T22:00:00Z",\n      "timestamp_local": "2026-05-26T15:00:00-07:00",\n      "day": 6,\n      "title": "7 arrests during evacuation; millions of gallons of water used to cool tank",\n      "description": "At the Day 6 evening press conference, Garden Grove Police Chief Amir El-Farra reports 7 total arrests since the incident began: 1 for looting and 6 for prowling; DA\'s office to prosecute to fullest extent. OCFA Incident Commander Craig Covey reveals scale of cooling operations: a deluge system plus a ground monitor flowing 1,250 gallons per minute for five consecutive days — totaling millions of gallons of water used.",\n      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/",\n      "source_name": "ABC7 LA",\n      "category": "official_statement"\n    },\n    {\n      "id": "evt-20260526-007",\n      "timestamp_utc": "2026-05-26T22:00:00Z",\n      "timestamp_local": "2026-05-26T15:00:00-07:00",\n      "day": 6,\n      "title": "Tank temperature steady at 92°F; main cooling hose stream deactivated",\n      "description": "OCFA Fire Capt. and PIO Greg Barta reports tank temperature holding at a steady 92°F, down from 100°F peak. Officials deactivate one of the main unmanned master hose streams that had been continuously spraying water on the tank for days. Onsite sprinkler system remains active. MMA continues to harden inside tank, further reducing spill threat.",\n      "source_url": "https://ktla.com/news/orange-county/garden-grove-chemical-tank-evacuation-update/",\n      "source_name": "KTLA",\n      "category": "tank_status"\n    },\n    {\n      "id": "evt-20260526-008",\n      "timestamp_utc": "2026-05-26T22:00:00Z",\n      "timestamp_local": "2026-05-26T15:00:00-07:00",\n      "day": 6,\n      "title": "Crews begin transferring MMA from third unaffected tank into neutralizing-agent tank",\n      "description": "Officials announce crews are moving product from the third, unaffected GKN Aerospace tank into a second tank that already contains a neutralizing agent — creating the conditions to eventually neutralize and isolate the MMA from the compromised primary tank. The primary tank\'s seized valves continue to prevent direct offloading of its contents.",\n      "source_url": "https://www.nbclosangeles.com/news/local/toxic-chemical-tank-garden-grove-orange-county/3894971/",\n      "source_name": "NBC LA",\n      "category": "tank_status"\n    },\n    {\n      "id": "evt-20260526-005",\n      "timestamp_utc": "2026-05-27T00:30:00Z",\n      "timestamp_local": "2026-05-26T17:30:00-07:00",\n      "day": 6,\n      "title": "Garden Grove City Council holds special meeting on tank crisis",\n      "description": "City of Garden Grove holds special City Council meeting focused on the incident, the city\'s response, and the latest information available.",\n      "source_url": "https://ggcity.org/emergency",\n      "source_name": "City of Garden Grove",\n      "category": "government_action"\n    },\n    {\n      "id": "evt-20260527-001",\n      "timestamp_utc": "2026-05-27T14:00:00Z",\n      "timestamp_local": "2026-05-27T07:00:00-07:00",\n      "day": 7,\n      "title": "McGovern: water cooling to be shut down system by system to test tank stability",\n      "description": "OCFA Interim Fire Chief TJ McGovern announces at Tuesday morning briefing that crews will begin gradually shutting down the two water-cooling systems to test whether the tank can stabilize on its own. \\"We\'re going to shut down one of those two systems, and we\'re going to monitor the temperature. We\'re looking for it to stabilize. We don\'t want it to come up. We\'re hoping it comes down. If that looks good throughout the day, then we\'re going to shut down the second system, and we are going to watch that.\\" Tank temperature holding steady at 92°F.",\n      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/",\n      "source_name": "ABC7 LA",\n      "category": "tank_status"\n    },\n    {\n      "id": "evt-20260527-003",\n      "timestamp_utc": "2026-05-27T20:00:00Z",\n      "timestamp_local": "2026-05-27T13:00:00-07:00",\n      "day": 7,\n      "title": "DA Spitzer expands criminal investigation; adds price-gouging probe",\n      "description": "Orange County District Attorney Todd Spitzer announces expansion of the criminal investigation into GKN Aerospace. The scope now includes alleged price gouging by third parties and predatory solicitation practices by attorneys targeting evacuees. Spitzer: he wants to make sure anyone impacted, including tens of thousands forced from their homes, is made whole. His office is looking into price gouging to prevent illicit activity.",\n      "source_url": "https://www.nbclosangeles.com/news/local/garden-grove-gkn-chemical-tank-criminal-investigation-todd-spitzer/3895460/",\n      "source_name": "NBC LA",\n      "category": "government_action"\n    },\n    {\n      "id": "evt-20260527-005",\n      "timestamp_utc": "2026-05-27T21:00:00Z",\n      "timestamp_local": "2026-05-27T14:00:00-07:00",\n      "day": 7,\n      "title": "Gov. Newsom directs statewide review of chemical plant safety records",\n      "description": "Governor Gavin Newsom announces that state officials are beginning to review GKN Aerospace\'s safety records and those of other chemical plant operators in California in the wake of the Garden Grove emergency.",\n      "source_url": "https://en.wikipedia.org/wiki/Garden_Grove_chemical_leak",\n      "source_name": "Wikipedia",\n      "category": "government_action"\n    },\n    {\n      "id": "evt-20260527-002",\n      "timestamp_utc": "2026-05-27T23:00:00Z",\n      "timestamp_local": "2026-05-27T16:00:00-07:00",\n      "day": 7,\n      "title": "All water cooling deactivated; crews walk and climb tank as MMA solidifies",\n      "description": "AIR7 aerial video above GKN Aerospace shows no water being sprayed on the tank. Both cooling systems shut down; crews observed walking around the tank and climbing on top. Focus shifts from explosion prevention to assessing how to safely access the tank interior. MMA believed to be solidifying inside. OCFA Chief McGovern: \\"We gotta get the fire problem handled first, stabilize that temperature, and then the team will make that determination — now, how do we get inside?\\" 16,000 residents remain under reduced evacuation orders.",\n      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/",\n      "source_name": "ABC7 LA",\n      "category": "tank_status"\n    },\n    {\n      "id": "evt-20260527-004",\n      "timestamp_utc": "2026-05-28T01:00:00Z",\n      "timestamp_local": "2026-05-27T18:00:00-07:00",\n      "day": 7,\n      "title": "Residents demand GKN accountability at Garden Grove City Council meeting",\n      "description": "At a second special Tuesday evening City Council meeting, OCFA Incident Commander Craig Covey and Garden Grove Police Chief Amir El-Farra break the news that evacuation orders will be lifted. Angry residents demand accountability from city leaders and GKN Aerospace, questioning why a company handling such chemicals operates so close to homes, schools, and businesses. Garden Grove Mayor Stephanie Klopfenstein pledges GKN will be held accountable: \\"Our community deserves to know what happened, why it happened and whether laws or regulations were violated, and what steps we must take to prevent something like this from ever happening again.\\"",\n      "source_url": "https://voiceofoc.org/2026/05/evacuations-end-in-garden-grove-chemical-tank-emergency/",\n      "source_name": "Voice of OC",\n      "category": "government_action"\n    },\n    {\n      "id": "evt-20260528-001",\n      "timestamp_utc": "2026-05-28T02:30:00Z",\n      "timestamp_local": "2026-05-27T19:30:00-07:00",\n      "day": 7,\n      "title": "All evacuation orders lifted; OCFA, county health, and EPA declare no risk",\n      "description": "OCFA announces all evacuation orders lifted at 7:30 PM PDT for the final 16,000 remaining evacuees — ending a 7-day crisis that displaced up to 50,000 residents. County health officials, OCFA fire crews, and the EPA jointly confirmed no chemical leak, no threat of explosion, no threat of fire, and no risk to the public from the damaged GKN Aerospace tank. EPA on-scene coordinator Chris Myers: \\"No exceedances have been detected at any time throughout this event. There was no contamination. There were no fumes. There were no vapors that came from this incident.\\" No injuries were reported during the entire 7-day incident.",\n      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/",\n      "source_name": "ABC7 LA",\n      "category": "evacuation"\n    },\n    {\n      "id": "evt-20260528-002",\n      "timestamp_utc": "2026-05-28T03:30:00Z",\n      "timestamp_local": "2026-05-27T20:30:00-07:00",\n      "day": 7,\n      "title": "Residents return home; community demands GKN accountability",\n      "description": "Following the 7:30 PM PDT all-clear, tens of thousands of residents returned home after the 7-day evacuation. Many expressed relief but also anger over the week-long displacement. Rep. Derek Tran (CA-45): \\"While immediate danger has been lifted, residents are still left to pick up the pieces. Our community is rightfully angry, and I will continue working around the clock to demand accountability from all responsible actors.\\" NBC LA reported the evacuation order for all Garden Grove residents was officially lifted by the Garden Grove Police Department. GKN Aerospace\'s prior $909,935.95 SCAQMD settlement from early 2025 — stemming from air quality violations first cited in a 2020 inspection — drew renewed scrutiny as residents demanded answers about how the company was permitted to store hazardous chemicals so close to homes and schools.",\n      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/entry/19172551/",\n      "source_name": "ABC7 LA",\n      "category": "community_impact"\n    },\n    {\n      "id": "evt-20260528-003",\n      "timestamp_utc": "2026-05-28T05:00:00Z",\n      "timestamp_local": "2026-05-27T22:00:00-07:00",\n      "day": 7,\n      "title": "GGUSD announces all 12 closed campuses reopen Wednesday — last day of school year",\n      "description": "Garden Grove Unified School District announces all schools will reopen Wednesday, May 28 — the final day of the school year. Students will not be penalized if unable to attend as families continue to recover; students held harmless on grades. The announcement follows the 7:30 PM PDT all-clear. Hazmat crews remain on Western Ave treating remaining MMA within a 300-foot exclusion zone around the GKN tanks.",\n      "source_url": "https://www.ggusd.us/news/evacuation-orders-lifted-all-schools-reopen-tomorrowevacuation-orders-lifted-all-schools-reopen-tomorrow",\n      "source_name": "GGUSD",\n      "category": "school_closure"\n    },\n    {\n      "id": "evt-20260528-004",\n      "timestamp_utc": "2026-05-28T14:00:00Z",\n      "timestamp_local": "2026-05-28T07:00:00-07:00",\n      "day": 8,\n      "title": "Evacuation shelters formally close; SBDC business recovery webinar announced",\n      "description": "Orange County officials announce formal closure of four evacuation shelters opened during the 7-day crisis, including Golden West College (Huntington Beach), Los Amigos High School (Fountain Valley), and Los Alamitos High School. Ongoing support services and recovery resources remain available. The Small Business Development Center (SBDC) announces a free webinar for businesses impacted by the chemical incident, covering available federal, state, county, and local resources, business support services, and guidance. Western Ave remains closed between Chapman Ave and Garden Grove Blvd with a 300-ft exclusion zone as hazmat crews continue treating solidified MMA around the GKN tanks.",\n      "source_url": "https://ktla.com/news/orange-county/where-orange-county-evacuees-can-find-assistance-amid-garden-grove-chemical-leak-incident/",\n      "source_name": "KTLA",\n      "category": "community_impact"\n    },\n    {\n      "id": "evt-20260528-005",\n      "timestamp_utc": "2026-05-28T17:00:00Z",\n      "timestamp_local": "2026-05-28T10:00:00-07:00",\n      "day": 8,\n      "title": "Former GKN employee raises prior safety concerns; urges use of right-to-know laws",\n      "description": "Valerie Morales, a former environmental health and safety manager who spent 18 years in the field including time at GKN Aerospace\'s Santa Ana facility, speaks to Fox 11 Los Angeles about the crisis. Morales calls the incident a wake-up call and urges California residents to use existing \\"right-to-know\\" laws to research hazardous materials stored in facilities near their homes. Her comments come as the Orange County DA\'s criminal investigation continues and multiple class-action lawsuits are filed against GKN Aerospace.",\n      "source_url": "https://www.foxla.com/news/former-gkn-employee-speaks-out-garden-grove-chemical-theft",\n      "source_name": "FOX 11 Los Angeles",\n      "category": "media_coverage"\n    },\n    {\n      "id": "evt-20260528-006",\n      "timestamp_utc": "2026-05-28T18:00:00Z",\n      "timestamp_local": "2026-05-28T11:00:00-07:00",\n      "day": 8,\n      "title": "GKN Aerospace SVP Steve Carlin issues formal apology to displaced community",\n      "description": "GKN Aerospace Senior Vice President Steve Carlin issues a formal public apology for the 7-day chemical tank crisis: \\"On behalf of the team at GKN Aerospace, I want to say how sorry we are for the uncertainty and disruption this situation has caused. The past several days have been difficult for residents, businesses, and the broader Garden Grove, Stanton, and surrounding Orange County communities. We are relieved that the incident has been resolved and residents have been able to return home.\\" The statement comes as hundreds of angry residents demand accountability and the permanent closure of the GKN facility, and as the Orange County DA\'s criminal investigation, multiple class-action lawsuits, and community pressure continue.",\n      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/",\n      "source_name": "ABC7 LA",\n      "category": "official_statement"\n    },\n    {\n      "id": "evt-20260528-008",\n      "timestamp_utc": "2026-05-28T19:00:00Z",\n      "timestamp_local": "2026-05-28T12:00:00-07:00",\n      "day": 8,\n      "title": "37+ lawsuits filed against GKN Aerospace in OC and federal courts",\n      "description": "As of Day 8, 29 claims against GKN Aerospace have been filed in Orange County Superior Court and approximately 8 in federal court — beyond the initial class-action filed May 23 — as residents and attorneys continue to seek damages for the 7-day displacement of up to 50,000 people. Separately, a coalition of community and advocacy groups is calling for permanent closure of the GKN Garden Grove facility. The Orange County DA criminal investigation remains open.",\n      "source_url": "https://mynewsla.com/orange-county/2026/05/28/legal-troubles-mount-for-garden-grove-aerospace-facility/",\n      "source_name": "MyNewsLA",\n      "category": "government_action"\n    },\n    {\n      "id": "evt-20260528-009",\n      "timestamp_utc": "2026-05-28T21:00:00Z",\n      "timestamp_local": "2026-05-28T14:00:00-07:00",\n      "day": 8,\n      "title": "Community recovery meeting at Cal State Fullerton for evacuees",\n      "description": "A community recovery meeting is held at California State University Fullerton for residents displaced by the 7-day chemical emergency. Consumer protection experts are available, and OCFA Interim Fire Chief TJ McGovern attends to brief the public. The meeting runs until approximately 5:30 PM PDT, after which many residents head to a Garden Grove City Council session to continue demanding accountability from GKN Aerospace and city leadership.",\n      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/entry/19177243/",\n      "source_name": "ABC7 LA",\n      "category": "community_impact"\n    },\n    {\n      "id": "evt-20260528-007",\n      "timestamp_utc": "2026-05-28T22:00:00Z",\n      "timestamp_local": "2026-05-28T15:00:00-07:00",\n      "day": 8,\n      "title": "All roads around GKN Aerospace fully reopen; 300-ft exclusion zone only remains",\n      "description": "OCFA confirms all roads closed during the 7-day chemical emergency — including Western Ave between Chapman Ave and Garden Grove Blvd — have fully reopened. The only restriction remaining is a 300-foot exclusion zone immediately surrounding the GKN Aerospace tanks, where hazmat crews continue treating and monitoring the solidified MMA. The Orange County DA criminal investigation and multiple class-action lawsuits remain ongoing.",\n      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/",\n      "source_name": "ABC7 LA",\n      "category": "evacuation"\n    },\n    {\n      "id": "evt-20260529-001",\n      "timestamp_utc": "2026-05-29T15:00:00Z",\n      "timestamp_local": "2026-05-29T08:00:00-07:00",\n      "day": 9,\n      "title": "City launches community impact survey; OC United Way opens recovery fund",\n      "description": "The City of Garden Grove launches an online community impact survey asking residents and businesses to document the effects of the evacuation and chemical emergency (ggcity.org/hazmat-incident/survey). Separately, Orange County United Way launches the OC Community Resilience Fund to provide direct financial support for residents and businesses in Garden Grove, Stanton, Westminster, Cypress, Anaheim, and Buena Park affected by the incident.",\n      "source_url": "https://ggcity.org/emergency",\n      "source_name": "City of Garden Grove",\n      "category": "government_action"\n    },\n    {\n      "id": "evt-20260529-002",\n      "timestamp_utc": "2026-05-29T17:00:00Z",\n      "timestamp_local": "2026-05-29T10:00:00-07:00",\n      "day": 9,\n      "title": "Residents publicly call for permanent GKN Aerospace plant closure",\n      "description": "KTLA reports hundreds of Garden Grove residents are publicly demanding the permanent closure of the GKN Aerospace facility at 12122 Western Ave. Community members question how a company handling explosive industrial chemicals was permitted to operate within a mile of homes and schools. The City Council took no action at the special meeting despite chants and pleas from residents. The Orange County DA criminal investigation, multiple class-action lawsuits, and prior SCAQMD settlement history continue to fuel community pressure.",\n      "source_url": "https://ktla.com/news/orange-county/garden-grove-chemical-scare-gkn-aerospace/",\n      "source_name": "KTLA",\n      "category": "community_impact"\n    },\n    {\n      "id": "evt-20260529-003",\n      "timestamp_utc": "2026-05-29T19:00:00Z",\n      "timestamp_local": "2026-05-29T12:00:00-07:00",\n      "day": 9,\n      "title": "Mass tort against GKN Aerospace surpasses 100 plaintiffs; multiple class-actions filed",\n      "description": "More than 100 people have joined a mass tort lawsuit against GKN Aerospace following the 7-day chemical emergency. Beyond the initial X-Law Group class action (filed May 23), DiCello Levitt LLP filed a separate federal class action on May 27 on behalf of evacuated property owners and renters, and a second federal case (Sanchez v. GKN Aerospace Transparency Systems, Case No. 8:26-cv-01296, C.D. Cal.) was filed May 26. Westminster, Anaheim, and the Orange County Board of Supervisors ratified local emergencies at their May 28 meetings, a step officials say is necessary to pursue state and federal reimbursement for displaced residents and affected businesses. The Orange County DA criminal investigation remains open.",\n      "source_url": "https://ktla.com/news/orange-county/class-action-lawsuit-filed-chemical-leak-crisis-garden-grove/",\n      "source_name": "KTLA",\n      "category": "government_action"\n    },\n    {\n      "id": "evt-20260529-004",\n      "timestamp_utc": "2026-05-29T21:00:00Z",\n      "timestamp_local": "2026-05-29T14:00:00-07:00",\n      "day": 9,\n      "title": "OC Board Chair Chaffee calls on GKN to set up compensation claims process",\n      "description": "Orange County Board of Supervisors Chair Doug Chaffee publicly calls on GKN Aerospace to establish a compensation and claims process for the approximately 50,000 displaced residents and affected businesses. \\"We encourage them to set up a claims process and acknowledge responsibility. We\'re looking for that to happen, so the public can be reimbursed.\\" Chaffee says GKN should compensate businesses forced to shut down, residents who lost wages, and those who incurred hotel and displacement expenses. Details on how and when reimbursement would occur remain unclear, with county officials still exploring options. OC County has filed for FEMA reimbursement for government response costs, while pushing GKN to pay for private losses.",\n      "source_url": "https://voiceofoc.org/2026/05/oc-residents-impacted-by-faulty-chemical-tank-may-get-reimbursed/",\n      "source_name": "Voice of OC",\n      "category": "government_action"\n    },\n    {\n      "id": "evt-20260529-005",\n      "timestamp_utc": "2026-05-29T22:00:00Z",\n      "timestamp_local": "2026-05-29T15:00:00-07:00",\n      "day": 9,\n      "title": "OC Workforce launches SBA assistance program for chemical incident businesses",\n      "description": "Orange County Workforce & Economic Development Division announces that small businesses impacted by the Garden Grove chemical emergency may complete and submit an SBA Economic Injury Disaster Loan (EIDL) worksheet to determine eligibility for assistance programs. Businesses in Garden Grove, Stanton, Anaheim, Cypress, Westminster, and Buena Park affected by the 7-day evacuation can email completed forms to EOCLiaison@ocsheriff.gov or call (866) 500-6587. Separately, the Orange County government publishes a consolidated GKN HazMat incident recovery page at ocgov.com/gkn-aerospace-hazmat-incident.",\n      "source_url": "https://workforce.ocgov.com/press/small-businesses-impacted-garden-grove-chemical-incident-encouraged-submit-sba-assistance",\n      "source_name": "OC Workforce & Economic Development Division",\n      "category": "government_action"\n    },\n    {\n      "id": "evt-20260529-006",\n      "timestamp_utc": "2026-05-29T23:00:00Z",\n      "timestamp_local": "2026-05-29T16:00:00-07:00",\n      "day": 9,\n      "title": "Evacuees report insurance claims denied; no GKN reimbursement process established",\n      "description": "NBC Los Angeles reports some evacuees are finding their homeowners insurance claims denied for displacement costs incurred during the 7-day evacuation. At least one evacuee filed a claim under the \\"civil authority\\" clause of their policy for hotel costs but was denied. Despite pressure from OC Board Chair Doug Chaffee and elected officials, GKN Aerospace has not established a formal claims or reimbursement process for the roughly 50,000 displaced residents and affected businesses. GKN said it is \\"committed to understanding what occurred and identifying ways\\" to support victims. The county is asking GKN to help cover losses, and has urged business owners to document losses and submit forms for potential state/SBA assistance.",\n      "source_url": "https://www.nbclosangeles.com/news/local/garden-grove-chemical-tank-crisis-victims-financial-assistance/3896612/",\n      "source_name": "NBC LA",\n      "category": "community_impact"\n    },\n    {\n      "id": "evt-20260530-001",\n      "timestamp_utc": "2026-05-30T14:00:00Z",\n      "timestamp_local": "2026-05-30T07:00:00-07:00",\n      "day": 10,\n      "title": "CA Dept. of Education offers J-13A waiver support for affected school districts",\n      "description": "California State Superintendent of Public Instruction Tony Thurmond launches a campaign to support schools affected by the Garden Grove chemical tank emergency. The California Department of Education encourages impacted school districts and charter schools to submit J-13A waivers to help avoid attendance-based funding losses tied to emergency school closures during the 7-day incident.",\n      "source_url": "https://www.cde.ca.gov/nr/ne/yr26/yr26rel32.asp",\n      "source_name": "CA Dept. of Education",\n      "category": "government_action"\n    },\n    {\n      "id": "evt-20260530-002",\n      "timestamp_utc": "2026-05-30T17:00:00Z",\n      "timestamp_local": "2026-05-30T10:00:00-07:00",\n      "day": 10,\n      "title": "EPA, OC Health, SCAQMD, and GKN begin formal cleanup and removal plan coordination",\n      "description": "OCFA Deputy Incident Commander Mike Yeun confirms that the formal cleanup and removal phase has begun: \\"We will work with Orange County Health, and the EPA will work with the company on the removal of the waste.\\" OC Health Care Agency hazmat team, South Coast AQMD, EPA, and GKN Aerospace are responsible for developing the removal plan; detailed timelines are pending. A 300-foot exclusion zone remains around the GKN tanks while hazmat crews continue monitoring the solidified MMA.",\n      "source_url": "https://www.nbclosangeles.com/news/local/garden-grove-chemical-tank-whats-next-financial-fallout/3895967/",\n      "source_name": "NBC LA",\n      "category": "government_action"\n    }\n  ],\n  "generated_at": "2026-05-30T01:08:25Z"\n}