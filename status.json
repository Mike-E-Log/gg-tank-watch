  "official_statements": [
    {
      "agency": "OCFA Unified Command",
      "time_iso": "2026-05-28T02:30:00Z",
      "text": "All evacuation orders related to the Garden Grove hazardous materials incident have been lifted. No active chemical leak. No threat of explosion. No threat of fire. No risk to the public.",
      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/"
    },
    {
      "agency": "EPA on-scene coordinator Chris Myers",
      "time_iso": "2026-05-28T02:00:00Z",
      "text": "No exceedances have been detected at any time throughout this event. There was no contamination. There were no fumes. There were no vapors that came from this incident.",
      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/"
    },
    {
      "agency": "Garden Grove Mayor Stephanie Klopfenstein",
      "time_iso": "2026-05-28T01:00:00Z",
      "text": "Our community deserves to know what happened, why it happened and whether laws or regulations were violated, and what steps we must take to prevent something like this from ever happening again.",
      "source_url": "https://voiceofoc.org/2026/05/evacuations-end-in-garden-grove-chemical-tank-emergency/"
    },
    {
      "agency": "GKN Aerospace SVP Steve Carlin",
      "time_iso": "2026-05-28T18:00:00Z",
      "text": "On behalf of the team at GKN Aerospace, I want to say how sorry we are for the uncertainty and disruption this situation has caused. The past several days have been difficult for residents, businesses, and the broader Garden Grove, Stanton, and surrounding Orange County communities. We are relieved that the incident has been resolved and residents have been able to return home.",
      "source_url": "https://www.cbsnews.com/losangeles/news/california-chemical-incident-orange-county-evacuation-orders-removed/"
    },
    {
      "agency": "OCFA (roads reopening)",
      "time_iso": "2026-05-28T22:00:00Z",
      "text": "All roads that were closed around GKN Aerospace as a result of the hazardous materials incident have reopened. A 300-foot exclusion zone around the tank remains in place as hazmat crews continue treating solidified MMA.",
      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/"
    }
  ],
