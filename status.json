  "official_statements": [
    {
      "agency": "Orange County Health Care Agency / CUPA",
      "time_iso": "2026-05-29T00:00:00Z",
      "text": "Beginning May 29, 2026, the Orange County Health Care Agency (HCA), serving as the County's Certified Unified Program Agency (CUPA), will lead multi-agency site cleanup and waste removal activities related to the incident, working closely with GKN Aerospace. During the cleanup process, air monitoring will be conducted at the GKN Aerospace fence line and in the community under the oversight of South Coast Air Quality Management District (AQMD).",
      "source_url": "https://www.ocgov.com/gkn-aerospace-hazmat-incident"
    },
    {
      "agency": "City of Garden Grove",
      "time_iso": "2026-05-30T00:00:00Z",
      "text": "All evacuation orders related to the hazardous materials incident have been lifted. Orange County health officials have confirmed there are no air quality or other health concerns in the area. The safety zone around the involved tank has been reduced to 150 feet.",
      "source_url": "https://ggcity.org/emergency"
    }
  ],
