  "official_statements": [
    {
      "agency": "OCFA \u2013 Interim Fire Chief TJ McGovern",
      "time_iso": "2026-05-25T21:00:00Z",
      "text": "The most catastrophic and worst case scenario was mitigated and resolved.",
      "source_url": "https://voiceofoc.org/2026/05/garden-grove-chemical-tank-evacuations-partially-lifted-16k-still-evacuated/"
    },
    {
      "agency": "OCFA \u2013 Incident Commander Craig Covey",
      "time_iso": "2026-05-25T21:00:00Z",
      "text": "I was handed an incident that had two options \u2013 a spill or an explosion.",
      "source_url": "https://voiceofoc.org/2026/05/garden-grove-chemical-tank-evacuations-partially-lifted-16k-still-evacuated/"
    },
    {
      "agency": "OCFA",
      "time_iso": "2026-05-25T21:03:00Z",
      "text": "Due to the threat of the BLEVE being eliminated, Fire & Law are re-evaluating the evacuation zones.",
      "source_url": "https://ggcity.org/emergency"
    },
    {
      "agency": "OC Health Officer Dr. Regina Chinsio-Kwong",
      "time_iso": "2026-05-25T21:00:00Z",
      "text": "There was no contamination, no fumes, no vapors. You should feel comfortable going home. Even if you're across the street from that new zone line.",
      "source_url": "https://voiceofoc.org/2026/05/garden-grove-chemical-tank-evacuations-partially-lifted-16k-still-evacuated/"
    },
    {
      "agency": "OCFA \u2013 Incident Commander Craig Covey",
      "time_iso": "2026-05-26T14:00:00Z",
      "text": "The liquid potential in the tank [has been] greatly reduced, as it has been hardened.",
      "source_url": "https://www.cbsnews.com/losangeles/video/ocfa-chief-craig-covey-talks-about-resolving-the-garden-grove-emergency/"
    },
    {
      "agency": "Garden Grove PD Chief Amir El-Farra",
      "time_iso": "2026-05-27T01:00:00Z",
      "text": "Seven total arrests have been made since the incident began \u2014 one person for looting and six for prowling. The DA\u2019s office will prosecute them to the fullest extent of the law.",
      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/entry/19172203/"
    },
    {
      "agency": "OCFA \u2013 Incident Commander Craig Covey",
      "time_iso": "2026-05-27T01:00:00Z",
      "text": "So, you got a deluge system with a full throttle on it, and then we have that ground monitor on the ground that\u2019s flowing 1,250 gallons a minute, so imagine five days of that.",
      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/entry/19172480/"
    }
  ],
