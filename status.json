  "official_statements": [
    {
      "agency": "OCFA / Unified Command",
      "time_iso": "2026-05-28T02:30:00Z",
      "text": "No chemical leak, no threat of explosion, no threat of fire, and no risk to the public from the damaged GKN Aerospace tank. All evacuation orders are lifted.",
      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/"
    },
    {
      "agency": "Orange County (ocgov.com)",
      "time_iso": "2026-05-28T01:00:00Z",
      "text": "All Care and Shelter locations were closed as of 6 pm May 27, 2026. All road closures were lifted as of 6 pm May 27, 2026. The evacuation zone remains for 150 feet around the GKN facility.",
      "source_url": "https://www.ocgov.com/page/garden-grove-chemical-spill-incident"
    },
    {
      "agency": "OC Board of Supervisors Chair Doug Chaffee",
      "time_iso": "2026-05-29T17:00:00Z",
      "text": "We encourage them to set up a claims process and acknowledge responsibility. We're looking for that to happen, so the public can be reimbursed.",
      "source_url": "https://voiceofoc.org/2026/05/oc-residents-impacted-by-faulty-chemical-tank-may-get-reimbursed/"
    },
    {
      "agency": "OC Workforce & Economic Development Division",
      "time_iso": "2026-05-29T22:00:00Z",
      "text": "Small businesses impacted by the recent chemical incident in Garden Grove are encouraged to complete and submit an SBA Economic Injury Disaster Loan worksheet to help determine eligibility for potential assistance programs.",
      "source_url": "https://workforce.ocgov.com/press/small-businesses-impacted-garden-grove-chemical-incident-encouraged-submit-sba-assistance"
    }
  ],
