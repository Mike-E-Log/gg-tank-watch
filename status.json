  "official_statements": [
    {
      "agency": "OCFA (Interim Fire Chief T.J. McGovern)",
      "time_iso": "2026-05-25T14:00:00Z",
      "text": "We are happy to report that the threat of BLEVE is off the table. That threat has been eliminated. Crisis is not averted \u2014 we still have potential for an explosion that is not as bad as a BLEVE, but it is still a threat. We are not there yet, but this was a step in the right direction.",
      "source_url": "https://www.nbclosangeles.com/news/local/garden-grove-chemical-tank-evacuations/3894765/"
    },
    {
      "agency": "OCFA (Incident Commander Craig Covey)",
      "time_iso": "2026-05-25T14:00:00Z",
      "text": "That is incredibly positive news as we turn the corner on this incident. The crack is there. We have verified that it is there and the tank has released its pressure. Tank temperature has stabilized and is now decreasing, dropping from about 100 degrees to 93 degrees.",
      "source_url": "https://www.newsweek.com/garden-grove-california-chemical-tank-update-crack-forecast-good-news-11990075"
    },
    {
      "agency": "City of Garden Grove",
      "time_iso": "2026-05-25T00:00:00Z",
      "text": "Yesterday's cooling operation was successful and crews initially made progress toward product removal; however, damage to a valve on the tank has created additional operational challenges, preventing complete mitigation at this time. Due to changing conditions, evacuation orders are being reissued as a precautionary measure while mitigation operations continue.",
      "source_url": "https://ggcity.org/emergency"
    }
  ],
