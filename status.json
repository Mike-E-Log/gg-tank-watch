    "name": "Garden Grove MMA Tank Leak",
    "facility": "GKN Aerospace, Garden Grove, CA",
    "started_iso": "2026-05-21T22:40:00Z",
    "status_headline": "BLEVE explosion threat eliminated after tank crack discovered and pressure released; evacuation zone reduced from ~50,000 to ~16,000 residents as of May 25 evening; tank temperature stabilizing but smaller explosion risk remains.",
    "severity": "high",
    "resolved_iso": null
  },
