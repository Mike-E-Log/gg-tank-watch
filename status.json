  "official_statements": [
    {
      "agency": "OCFA (Interim Fire Chief T.J. McGovern & Incident Commander Craig Covey)",
      "time_iso": "2026-05-25T16:00:00Z",
      "text": "The threat of a BLEVE \u2014 Boiling Liquid Expanding Vapor Explosion \u2014 is now off the table. A crack formed in the compromised tank, allowing pressure to safely release without causing a leak or explosion.",
      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/"
    },
    {
      "agency": "OCFA (Incident Commander Craig Covey)",
      "time_iso": "2026-05-25T16:00:00Z",
      "text": "Crisis is not averted. We still have potential for an explosion that's not as bad as a BLEVE, but it's still a threat. In order to further reduce the evacuation zone or eliminate it completely, crews need to continue to observe a trend of decreasing temperatures inside the tank.",
      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-ray/19152918/"
    },
    {
      "agency": "OCFA",
      "time_iso": "2026-05-26T01:00:00Z",
      "text": "Evacuation zone has been significantly reduced. Approximately 65% of impacted residents are now able to return home. Approximately 16,000 residents remain in the reduced evacuation zone.",
      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/entry/19171034/"
    },
    {
      "agency": "OC Health Officer (Dr. CK)",
      "time_iso": "2026-05-26T01:00:00Z",
      "text": "There was no contamination. There were no fumes. There were no vapors that came from this incident.",
      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/entry/19171322/"
    },
    {
      "agency": "GKN Aerospace",
      "time_iso": "2026-05-25T17:00:00Z",
      "text": "GKN Aerospace is working with officials to mitigate risk of a leak. On Sunday, a team from GKN worked with OCFA to remove external insulation from the tank to help cool the chemicals inside.",
      "source_url": "https://www.cbsnews.com/losangeles/news/california-chemical-leak-orange-county-garden-grove-emergency/"
    },
    {
      "agency": "OCFA",
      "time_iso": "2026-05-25T20:00:00Z",
      "text": "There is still no chemical leak, as verified by continuous atmospheric monitoring. Runoff from water sprayed on the tank into storm drains has been consistently tested and has been clean. Downstream barriers are in place but have not collected any contaminants.",
      "source_url": "https://newsroom.ocde.us/several-garden-grove-unified-campuses-closed-following-chemical-leak-response/"
    }
  ],
