  "official_statements": [
    {
      "agency": "OCFA / Unified Command",
      "time_iso": "2026-05-28T02:30:00Z",
      "text": "No chemical leak, no threat of explosion, no threat of fire, and no risk to the public from the damaged GKN Aerospace tank. All evacuation orders are lifted.",
      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/"
    },
    {
      "agency": "EPA (on-scene coordinator Chris Myers)",
      "time_iso": "2026-05-28T02:30:00Z",
      "text": "No exceedances have been detected at any time throughout this event. There was no contamination. There were no fumes. There were no vapors that came from this incident.",
      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/"
    },
    {
      "agency": "GKN Aerospace (SVP Steve Carlin)",
      "time_iso": "2026-05-28T18:00:00Z",
      "text": "On behalf of the team at GKN Aerospace, I want to say how sorry we are for the uncertainty and disruption this situation has caused. We are relieved that the incident has been resolved and residents have been able to return home.",
      "source_url": "https://www.cbsnews.com/losangeles/news/california-chemical-incident-orange-county-evacuation-orders-removed/"
    },
    {
      "agency": "City of Garden Grove",
      "time_iso": "2026-05-29T15:00:00Z",
      "text": "The City of Garden Grove is seeking information from residents, businesses and community members impacted by the recent chemical emergency. Residents and businesses are asked to complete an impact survey at ggcity.org/hazmat-incident/survey.",
      "source_url": "https://ggcity.org/emergency"
    },
    {
      "agency": "OC Board of Supervisors (Chair Doug Chaffee)",
      "time_iso": "2026-05-29T17:00:00Z",
      "text": "We encourage them to set up a claims process and acknowledge responsibility. We're looking for that to happen, so the public can be reimbursed.",
      "source_url": "https://voiceofoc.org/2026/05/oc-residents-impacted-by-faulty-chemical-tank-may-get-reimbursed/"
    }
  ],
