  "official_statements": [
    {
      "agency": "OCFA \u2013 Interim Fire Chief TJ McGovern",
      "time_iso": "2026-05-25T16:00:00Z",
      "text": "The threat of a BLEVE is now off the table.",
      "source_url": "https://ggcity.org/emergency"
    },
    {
      "agency": "OCFA",
      "time_iso": "2026-05-25T21:03:00Z",
      "text": "Due to the threat of the BLEVE being eliminated, Fire & Law are re-evaluating the evacuation zones.",
      "source_url": "https://ggcity.org/emergency"
    },
    {
      "agency": "OCFA \u2013 Interim Fire Chief TJ McGovern",
      "time_iso": "2026-05-25T21:00:00Z",
      "text": "The most catastrophic and worst case scenario was mitigated and resolved.",
      "source_url": "https://voiceofoc.org/2026/05/garden-grove-chemical-tank-evacuations-partially-lifted-16k-still-evacuated/"
    },
    {
      "agency": "OCFA \u2013 Incident Commander Craig Covey",
      "time_iso": "2026-05-25T21:00:00Z",
      "text": "I was handed an incident that had two options \u2013 a spill or an explosion.",
      "source_url": "https://voiceofoc.org/2026/05/garden-grove-chemical-tank-evacuations-partially-lifted-16k-still-evacuated/"
    },
    {
      "agency": "OC Health Officer Dr. Regina Chinsio-Kwong",
      "time_iso": "2026-05-24T23:00:00Z",
      "text": "There was no contamination, no fumes, no vapors. You should feel comfortable going home. Even if you're across the street from that new zone line.",
