  "official_statements": [
    {
      "agency": "OCFA",
      "time_iso": "2026-05-28T02:30:00Z",
      "text": "All evacuation orders related to the Garden Grove hazardous materials incident have been lifted. No chemical leak. No threat of explosion. No threat of fire. No risk to the public.",
      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/"
    },
    {
      "agency": "US EPA on-scene coordinator Chris Myers",
      "time_iso": "2026-05-28T02:00:00Z",
      "text": "No exceedances have been detected at any time throughout this event. There was no contamination. There were no fumes. There were no vapors that came from this incident.",
      "source_url": "https://abc7.com/live-updates/garden-grove-chemical-tank-emergency-leaking-toxic-chemicals-orange-county-will-spill-explode-officials-say/19152918/"
    },
    {
      "agency": "Rep. Derek Tran (CA-45)",
      "time_iso": "2026-05-28T03:00:00Z",
      "text": "While immediate danger has been lifted, residents are still left to pick up the pieces. Our community is rightfully angry, and I will continue working around the clock to demand accountability from all responsible actors.",
      "source_url": "https://voiceofoc.org/2026/05/evacuations-end-in-garden-grove-chemical-tank-emergency/"
    }
  ],
